+// TestGetVolumeCapabilitiesFromVRR covers the Filesystem branch (mount access type,
+// explicit fsType, fsType fallback to the executor default, StorageClass mount
+// options), the default ReadWriteOnce access mode, and the Block branch with RWX.
+func TestGetVolumeCapabilitiesFromVRR(t *testing.T) {
+	scWithMount := &storagev1.StorageClass{
+		ObjectMeta:   metav1.ObjectMeta{Name: vrrTestStorageClass},
+		Provisioner:  vrrTestDriverName,
+		MountOptions: []string{"noatime", "nodiratime"},
+	}
+
+	tests := []struct {
+		name           string
+		volumeMode     v1.PersistentVolumeMode
+		fsType         string
+		accessModes    []v1.PersistentVolumeAccessMode
+		sc             *storagev1.StorageClass
+		wantBlock      bool
+		wantFSType     string
+		wantMountFlags []string
+		wantAccessMode csi.VolumeCapability_AccessMode_Mode
+	}{
+		{
+			name:           "filesystem: default RWO, fsType fallback, SC mount options",
+			volumeMode:     v1.PersistentVolumeFilesystem,
+			sc:             scWithMount,
+			wantBlock:      false,
+			wantFSType:     vrrTestDefaultFSType,
+			wantMountFlags: []string{"noatime", "nodiratime"},
+			wantAccessMode: csi.VolumeCapability_AccessMode_SINGLE_NODE_WRITER,
+		},
+		{
+			name:           "filesystem: explicit fsType, no SC mount options",
+			volumeMode:     v1.PersistentVolumeFilesystem,
+			fsType:         "xfs",
+			sc:             ourStorageClass(),
+			wantBlock:      false,
+			wantFSType:     "xfs",
+			wantMountFlags: nil,
+			wantAccessMode: csi.VolumeCapability_AccessMode_SINGLE_NODE_WRITER,
+		},
+		{
+			name:           "block: RWX maps to MULTI_NODE_MULTI_WRITER",
+			volumeMode:     v1.PersistentVolumeBlock,
+			accessModes:    []v1.PersistentVolumeAccessMode{v1.ReadWriteMany},
+			sc:             ourStorageClass(),
+			wantBlock:      true,
+			wantAccessMode: csi.VolumeCapability_AccessMode_MULTI_NODE_MULTI_WRITER,
+		},
+	}
+
+	for _, tt := range tests {
+		t.Run(tt.name, func(t *testing.T) {
+			e := newTestExecutor(&mockControllerClient{}, nil, nil, nil, nil)
+			vrr := createTestVRR("test-vrr", "test-ns", "VolumeSnapshotContent", "test-vsc")
+			vrr.Spec.VolumeMode = tt.volumeMode
+			vrr.Spec.FsType = tt.fsType
+			vrr.Spec.AccessModes = tt.accessModes
+
+			caps, err := e.getVolumeCapabilitiesFromVRR(vrr, tt.sc)
+			if err != nil {
+				t.Fatalf("getVolumeCapabilitiesFromVRR failed: %v", err)
+			}
+			if len(caps) != 1 {
+				t.Fatalf("expected 1 capability, got %d", len(caps))
+			}
+			capability := caps[0]
+			if mode := capability.GetAccessMode().GetMode(); mode != tt.wantAccessMode {
+				t.Errorf("access mode = %v, want %v", mode, tt.wantAccessMode)
+			}
+			if tt.wantBlock {
+				if capability.GetBlock() == nil {
+					t.Errorf("expected Block access type, got %#v", capability.GetAccessType())
+				}
+				return
+			}
+			mount := capability.GetMount()
+			if mount == nil {
+				t.Fatalf("expected Mount access type, got %#v", capability.GetAccessType())
+			}
+			if mount.FsType != tt.wantFSType {
+				t.Errorf("fsType = %q, want %q", mount.FsType, tt.wantFSType)
+			}
+			if !equalStringSlices(mount.MountFlags, tt.wantMountFlags) {
+				t.Errorf("mountFlags = %v, want %v", mount.MountFlags, tt.wantMountFlags)
+			}
+		})
+	}
+}
