+func assertPVCBoundTo(t *testing.T, kubeClient kubernetes.Interface, pvName string) {
+	t.Helper()
+	pvc, err := kubeClient.CoreV1().PersistentVolumeClaims(vrrTestTargetNamespace).Get(context.Background(), vrrTestTargetPVCName, metav1.GetOptions{})
+	if err != nil {
+		t.Fatalf("expected target PVC to exist: %v", err)
+	}
+	if pvc.Spec.VolumeName != pvName {
+		t.Errorf("expected PVC bound to %s, got %s", pvName, pvc.Spec.VolumeName)
+	}
+	// PV.StorageClassName MUST equal PVC.StorageClassName, otherwise the
+	// persistentvolume-controller refuses to bind them (VolumeMismatch).
+	pv, err := kubeClient.CoreV1().PersistentVolumes().Get(context.Background(), pvName, metav1.GetOptions{})
+	if err != nil {
+		t.Fatalf("expected PV %s to exist: %v", pvName, err)
+	}
+	wantSC := ""
+	if pvc.Spec.StorageClassName != nil {
+		wantSC = *pvc.Spec.StorageClassName
+	}
+	if pv.Spec.StorageClassName != wantSC {
+		t.Errorf("PV/PVC StorageClassName mismatch: PV=%q PVC=%q (would fail to bind)", pv.Spec.StorageClassName, wantSC)
+	}
+}
