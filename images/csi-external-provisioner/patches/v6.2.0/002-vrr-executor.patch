+package controller
+
+import (
+	"context"
+	"fmt"
+	"maps"
+	"strings"
+	"time"
+
+	"github.com/container-storage-interface/spec/lib/go/csi"
+	"github.com/kubernetes-csi/csi-lib-utils/accessmodes"
+	"github.com/kubernetes-csi/csi-lib-utils/rpc"
+	snapclientset "github.com/kubernetes-csi/external-snapshotter/client/v8/clientset/versioned"
+	v1 "k8s.io/api/core/v1"
+	storagev1 "k8s.io/api/storage/v1"
+	apierrors "k8s.io/apimachinery/pkg/api/errors"
+	"k8s.io/apimachinery/pkg/api/meta"
+	metav1 "k8s.io/apimachinery/pkg/apis/meta/v1"
+	"k8s.io/apimachinery/pkg/apis/meta/v1/unstructured"
+	"k8s.io/apimachinery/pkg/runtime"
+	"k8s.io/apimachinery/pkg/types"
+	"k8s.io/apimachinery/pkg/util/wait"
+	"k8s.io/client-go/kubernetes"
+	storagelistersv1 "k8s.io/client-go/listers/storage/v1"
+	"k8s.io/client-go/tools/cache"
+	"k8s.io/client-go/tools/record"
+	"k8s.io/client-go/util/workqueue"
+	"k8s.io/klog/v2"
+
+	storagev1alpha1 "github.com/deckhouse/storage-foundation/api/v1alpha1"
+)
+
+// objectKeeperRefAnnotation carries the ObjectKeeper owner reference set by the
+// storage-foundation VRR lifecycle controller. The executor only consumes it.
+const objectKeeperRefAnnotation = "storage-foundation.deckhouse.io/object-keeper-ref"
+
+// VRRExecutor is the low-level executor of VolumeRestoreRequest (VRR) restore operations.
+//
+// Architecture (symmetric to VolumeCaptureRequest):
+//   - The VRR *lifecycle controller* lives in storage-foundation. It owns the CR
+//     lifecycle, ObjectKeeper, TTL, finalizers, conditions/status and high-level
+//     orchestration. It creates the ObjectKeeper, polls the target PVC and, when the
+//     PVC is Bound, sets VRR Ready=True (or Failed on a permanent error).
+//   - This executor (running inside external-provisioner) only performs the restore
+//     operation for VRRs targeting this CSI driver:
+//     watch/enqueue VRR -> filter by CSI driver -> validate source -> CSI CreateVolume
+//     -> create PV + PVC -> emit events. It is idempotent and retry-safe.
+//
+// The executor MUST NOT write VRR status. Status ownership belongs to the
+// storage-foundation controller. Retryable errors are requeued via the workqueue;
+// they never drive the VRR into a terminal state.
+type VRRExecutor struct {
+	kubeClient             kubernetes.Interface
+	csiClient              csi.ControllerClient
+	snapshotClient         snapclientset.Interface
+	driverName             string
+	identity               string
+	timeout                time.Duration
+	volumeNamePrefix       string
+	volumeNameUUIDLength   int
+	defaultFSType          string
+	scLister               storagelistersv1.StorageClassLister
+	eventRecorder          record.EventRecorder
+	pluginCapabilities     rpc.PluginCapabilitySet
+	controllerCapabilities rpc.ControllerCapabilitySet
+
+	vrrIndexer   cache.Indexer
+	vrrHasSynced cache.InformerSynced
+	queue        workqueue.TypedRateLimitingInterface[string]
+}
+
+// NewVRRExecutor creates a new VRR executor and registers the enqueue handlers on
+// the provided VRR informer. The informer is expected to be a dynamic informer for
+// the storage-foundation.deckhouse.io/v1alpha1 volumerestorerequests resource.
+func NewVRRExecutor(
+	kubeClient kubernetes.Interface,
+	csiClient csi.ControllerClient,
+	snapshotClient snapclientset.Interface,
+	driverName string,
+	identity string,
+	timeout time.Duration,
+	volumeNamePrefix string,
+	volumeNameUUIDLength int,
+	defaultFSType string,
+	scLister storagelistersv1.StorageClassLister,
+	vrrInformer cache.SharedIndexInformer,
+	eventRecorder record.EventRecorder,
+	pluginCapabilities rpc.PluginCapabilitySet,
+	controllerCapabilities rpc.ControllerCapabilitySet,
+) *VRRExecutor {
+	e := &VRRExecutor{
+		kubeClient:             kubeClient,
+		csiClient:              csiClient,
+		snapshotClient:         snapshotClient,
+		driverName:             driverName,
+		identity:               identity,
+		timeout:                timeout,
+		volumeNamePrefix:       volumeNamePrefix,
+		volumeNameUUIDLength:   volumeNameUUIDLength,
+		defaultFSType:          defaultFSType,
+		scLister:               scLister,
+		eventRecorder:          eventRecorder,
+		pluginCapabilities:     pluginCapabilities,
+		controllerCapabilities: controllerCapabilities,
+		vrrIndexer:             vrrInformer.GetIndexer(),
+		vrrHasSynced:           vrrInformer.HasSynced,
+		queue: workqueue.NewTypedRateLimitingQueueWithConfig(
+			workqueue.DefaultTypedControllerRateLimiter[string](),
+			workqueue.TypedRateLimitingQueueConfig[string]{Name: "volumerestorerequests"},
+		),
+	}
+
+	// The informer callback only enqueues a key; the actual restore runs in workers.
+	// This keeps the informer goroutine responsive and makes processing retry-safe.
+	if _, err := vrrInformer.AddEventHandler(cache.ResourceEventHandlerFuncs{
+		AddFunc:    e.enqueue,
+		UpdateFunc: func(_, newObj any) { e.enqueue(newObj) },
+	}); err != nil {
+		klog.Errorf("Failed to register VRR event handler: %v", err)
+	}
+
+	return e
+}
+
+// Run starts the executor workers and blocks until the context is cancelled.
+func (e *VRRExecutor) Run(ctx context.Context, workers int) {
+	defer e.queue.ShutDown()
+
+	klog.Info("Starting VRR executor")
+	if !cache.WaitForCacheSync(ctx.Done(), e.vrrHasSynced) {
+		klog.Error("Failed to wait for VRR informer cache to sync")
+		return
+	}
+
+	for i := 0; i < workers; i++ {
+		go wait.UntilWithContext(ctx, e.runWorker, time.Second)
+	}
+
+	<-ctx.Done()
+	klog.Info("Stopping VRR executor")
+}
+
+func (e *VRRExecutor) enqueue(obj any) {
+	key, err := cache.MetaNamespaceKeyFunc(obj)
+	if err != nil {
+		klog.Errorf("VRR enqueue: failed to derive key: %v", err)
+		return
+	}
+	e.queue.Add(key)
+}
+
+func (e *VRRExecutor) runWorker(ctx context.Context) {
+	for e.processNextItem(ctx) {
+	}
+}
+
+func (e *VRRExecutor) processNextItem(ctx context.Context) bool {
+	key, shutdown := e.queue.Get()
+	if shutdown {
+		return false
+	}
+	defer e.queue.Done(key)
+
+	if err := e.syncHandler(ctx, key); err != nil {
+		// Retryable error: requeue with rate limiting. This never marks the VRR
+		// terminal - terminal state is decided by the storage-foundation controller.
+		klog.Errorf("VRR %s: sync failed, requeueing: %v", key, err)
+		e.queue.AddRateLimited(key)
+		return true
+	}
+
+	e.queue.Forget(key)
+	return true
+}
+
+// syncHandler reads the VRR from the informer cache and runs the executor logic.
+func (e *VRRExecutor) syncHandler(ctx context.Context, key string) error {
+	obj, exists, err := e.vrrIndexer.GetByKey(key)
+	if err != nil {
+		return err
+	}
+	if !exists {
+		// VRR deleted - nothing for the executor to do; the controller and
+		// ObjectKeeper handle cleanup of any created artifacts.
+		klog.V(4).Infof("VRR %s: not found in cache, skipping", key)
+		return nil
+	}
+
+	u, ok := obj.(*unstructured.Unstructured)
+	if !ok {
+		klog.Warningf("VRR %s: unexpected object type %T, skipping", key, obj)
+		return nil
+	}
+
+	vrr := &storagev1alpha1.VolumeRestoreRequest{}
+	if err := runtime.DefaultUnstructuredConverter.FromUnstructured(u.UnstructuredContent(), vrr); err != nil {
+		// Malformed object is not retryable.
+		klog.Errorf("VRR %s: failed to convert object: %v", key, err)
+		return nil
+	}
+
+	return e.reconcile(ctx, vrr)
+}
+
+// reconcile performs the executor-only restore logic for a single VRR.
+//
+// It returns an error only for retryable conditions (so the workqueue retries).
+// Permanent/invalid requests are reported via events and return nil; the
+// storage-foundation controller is responsible for marking such VRRs terminal.
+func (e *VRRExecutor) reconcile(ctx context.Context, vrr *storagev1alpha1.VolumeRestoreRequest) error {
+	// Minimal validation.
+	if vrr.Spec.StorageClassName == "" {
+		e.eventRecorder.Eventf(vrr, v1.EventTypeWarning, "VRRInvalidSpec",
+			"StorageClassName is required but not specified")
+		klog.Warningf("VRR %s/%s has empty StorageClassName, ignoring", vrr.Namespace, vrr.Name)
+		return nil
+	}
+
+	// CRITICAL SECURITY INVARIANT: the driver filter MUST be the first executable
+	// step after minimal validation. In multi-CSI clusters this prevents this
+	// provisioner from acting on PVCs/PVs belonging to other CSI drivers.
+	sc, err := e.scLister.Get(vrr.Spec.StorageClassName)
+	if err != nil {
+		if apierrors.IsNotFound(err) {
+			// Not our StorageClass (or not present yet): ignore silently.
+			return nil
+		}
+		return err
+	}
+	if sc.Provisioner != e.driverName {
+		// Not our driver: ignore silently.
+		return nil
+	}
+
+	// Skip VRRs already driven to a terminal state by the controller (read-only).
+	if isTerminalVRR(vrr.Status.Conditions) {
+		klog.V(4).Infof("VRR %s/%s is terminal, skipping", vrr.Namespace, vrr.Name)
+		return nil
+	}
+
+	// VolumeMode is required: the executor builds CSI VolumeCapabilities from it and
+	// there is no implicit default. A wrong/empty mode silently breaks Block volumes,
+	// so reject it as a permanent invalid spec (event-only; status is the controller's).
+	// Validated only after the driver filter so foreign-driver VRRs stay untouched.
+	switch vrr.Spec.VolumeMode {
+	case v1.PersistentVolumeBlock, v1.PersistentVolumeFilesystem:
+	default:
+		e.eventRecorder.Eventf(vrr, v1.EventTypeWarning, "VRRInvalidSpec",
+			"VolumeMode is required and must be Block or Filesystem, got %q", vrr.Spec.VolumeMode)
+		klog.Warningf("VRR %s/%s has invalid VolumeMode %q, ignoring", vrr.Namespace, vrr.Name, vrr.Spec.VolumeMode)
+		return nil
+	}
+
+	// AccessModes are validated here so an invalid spec fails closed (event-only,
+	// return nil) symmetrically with VolumeMode, instead of looping forever in the
+	// retryable capability-conversion error path. Status remains the controller's.
+	if err := validateVRRAccessModes(vrr.Spec.AccessModes); err != nil {
+		e.eventRecorder.Eventf(vrr, v1.EventTypeWarning, "VRRInvalidSpec", "Invalid accessModes: %v", err)
+		klog.Warningf("VRR %s/%s has invalid accessModes %v: %v, ignoring", vrr.Namespace, vrr.Name, vrr.Spec.AccessModes, err)
+		return nil
+	}
+
+	// Deterministic target volume (PV) name derived from the VRR UID.
+	pvName, err := makeVolumeName(e.volumeNamePrefix, string(vrr.UID), e.volumeNameUUIDLength)
+	if err != nil {
+		return fmt.Errorf("failed to generate volume name: %w", err)
+	}
+
+	// Idempotency / conflict detection on the target PVC.
+	existingPVC, err := e.kubeClient.CoreV1().PersistentVolumeClaims(vrr.Spec.TargetNamespace).Get(ctx, vrr.Spec.TargetPVCName, metav1.GetOptions{})
+	switch {
+	case err == nil:
+		if existingPVC.Spec.VolumeName != "" && existingPVC.Spec.VolumeName != pvName {
+			// The target PVC is already bound to a different volume - likely a
+			// conflict with another owner. Report and let the controller decide.
+			e.eventRecorder.Eventf(vrr, v1.EventTypeWarning, "VRRTargetPVCConflict",
+				"Target PVC %s/%s is bound to volume %q, expected %q",
+				vrr.Spec.TargetNamespace, vrr.Spec.TargetPVCName, existingPVC.Spec.VolumeName, pvName)
+			klog.Warningf("VRR %s/%s: target PVC conflict (bound to %q, expected %q)",
+				vrr.Namespace, vrr.Name, existingPVC.Spec.VolumeName, pvName)
+			return nil
+		}
+		// Target PVC already created by a previous run: executor is done. The
+		// controller observes the PVC and finalizes the VRR status.
+		klog.V(4).Infof("VRR %s/%s: target PVC %s/%s already exists, nothing to do",
+			vrr.Namespace, vrr.Name, vrr.Spec.TargetNamespace, vrr.Spec.TargetPVCName)
+		return nil
+	case !apierrors.IsNotFound(err):
+		return fmt.Errorf("failed to check target PVC %s/%s: %w", vrr.Spec.TargetNamespace, vrr.Spec.TargetPVCName, err)
+	}
+
+	switch vrr.Spec.SourceRef.Kind {
+	case "VolumeSnapshotContent":
+		return e.restoreFromVSC(ctx, vrr, sc, pvName)
+	case "PersistentVolume":
+		return e.restoreFromPV(ctx, vrr, sc, pvName)
+	default:
+		e.eventRecorder.Eventf(vrr, v1.EventTypeWarning, "VRRInvalidSource",
+			"Unsupported source kind: %s", vrr.Spec.SourceRef.Kind)
+		klog.Warningf("VRR %s/%s has unsupported source kind %q, ignoring", vrr.Namespace, vrr.Name, vrr.Spec.SourceRef.Kind)
+		return nil
+	}
+}
+
+// restoreFromVSC restores a volume from a VolumeSnapshotContent and creates PV + PVC.
+//
+// It does not wait for the PVC to become Bound and does not update VRR status;
+// those are the responsibility of the storage-foundation controller.
+func (e *VRRExecutor) restoreFromVSC(ctx context.Context, vrr *storagev1alpha1.VolumeRestoreRequest, sc *storagev1.StorageClass, pvName string) error {
+	vsc, err := e.snapshotClient.SnapshotV1().VolumeSnapshotContents().Get(ctx, vrr.Spec.SourceRef.Name, metav1.GetOptions{})
+	if err != nil {
+		if apierrors.IsNotFound(err) {
+			// Source may appear later; retry.
+			return fmt.Errorf("VolumeSnapshotContent %s not found", vrr.Spec.SourceRef.Name)
+		}
+		return fmt.Errorf("failed to get VolumeSnapshotContent %s: %w", vrr.Spec.SourceRef.Name, err)
+	}
+
+	if vsc.ObjectMeta.DeletionTimestamp != nil {
+		return fmt.Errorf("VolumeSnapshotContent %s is currently being deleted", vsc.Name)
+	}
+
+	if vsc.Status == nil || vsc.Status.ReadyToUse == nil || !*vsc.Status.ReadyToUse {
+		if vsc.Status != nil && vsc.Status.Error != nil && vsc.Status.Error.Message != nil {
+			return fmt.Errorf("VolumeSnapshotContent %s has error: %s", vsc.Name, *vsc.Status.Error.Message)
+		}
+		// Not ready yet: retryable, not terminal.
+		return fmt.Errorf("VolumeSnapshotContent %s is not ReadyToUse yet", vsc.Name)
+	}
+
+	// CONTRACT: prefer Status.SnapshotHandle; fall back to Spec.Source.SnapshotHandle.
+	var snapshotHandle string
+	switch {
+	case vsc.Status != nil && vsc.Status.SnapshotHandle != nil:
+		snapshotHandle = *vsc.Status.SnapshotHandle
+	case vsc.Spec.Source.SnapshotHandle != nil:
+		snapshotHandle = *vsc.Spec.Source.SnapshotHandle
+	default:
+		return fmt.Errorf("snapshot handle not available in VolumeSnapshotContent %s", vsc.Name)
+	}
+
+	klog.V(2).Infof("restoreFromVSC: VRR %s/%s, VSC %s, snapshotHandle %s", vrr.Namespace, vrr.Name, vsc.Name, snapshotHandle)
+
+	// Build VolumeCapabilities from the VRR spec (volumeMode/fsType/accessModes)
+	// instead of hardcoding Filesystem/SINGLE_NODE_WRITER. CSI snapshots are
+	// mode-agnostic, so Block sources MUST be restored as Block volumes.
+	volumeCaps, err := e.getVolumeCapabilitiesFromVRR(vrr, sc)
+	if err != nil {
+		// An unsupported volumeMode/accessModes combination is a permanent spec
+		// problem, not a transient one: report it and stop (no requeue). The
+		// storage-foundation controller owns the terminal status.
+		e.eventRecorder.Eventf(vrr, v1.EventTypeWarning, "VRRInvalidSpec",
+			"Cannot build volume capabilities: %v", err)
+		klog.Warningf("VRR %s/%s: invalid volume capabilities, ignoring: %v", vrr.Namespace, vrr.Name, err)
+		return nil
+	}
+
+	capacityBytes := int64(1024 * 1024 * 1024) // 1Gi default
+	if vsc.Status != nil && vsc.Status.RestoreSize != nil {
+		capacityBytes = *vsc.Status.RestoreSize
+	}
+
+	contentSource := &csi.VolumeContentSource{
+		Type: &csi.VolumeContentSource_Snapshot{
+			Snapshot: &csi.VolumeContentSource_SnapshotSource{
+				SnapshotId: snapshotHandle,
+			},
+		},
+	}
+
+	pv, err := e.ensurePV(ctx, vrr, sc, pvName, volumeCaps, capacityBytes, contentSource, e.resolveFSType(vrr),
+		fmt.Sprintf("Successfully created PV %s from snapshot", pvName), effectiveAccessModes(vrr))
+	if err != nil {
+		return err
+	}
+
+	return e.createPVCFromVRR(ctx, vrr, pv)
+}
+
+// getVolumeCapabilitiesFromVRR builds CSI VolumeCapabilities from the VRR spec.
+//
+// volumeMode (required) selects Block vs Mount access type; accessModes (optional,
+// defaults to ReadWriteOnce) selects the CSI access mode; fsType (optional) and the
+// StorageClass mount options apply only to Filesystem volumes.
+func (e *VRRExecutor) getVolumeCapabilitiesFromVRR(vrr *storagev1alpha1.VolumeRestoreRequest, sc *storagev1.StorageClass) ([]*csi.VolumeCapability, error) {
+	supportsSingleNodeMultiWriter := e.controllerCapabilities[csi.ControllerServiceCapability_RPC_SINGLE_NODE_MULTI_WRITER]
+
+	csiAccessMode, err := accessmodes.ToCSIAccessMode(effectiveAccessModes(vrr), supportsSingleNodeMultiWriter)
+	if err != nil {
+		return nil, fmt.Errorf("failed to convert AccessModes to CSI access mode: %w", err)
+	}
+
+	switch vrr.Spec.VolumeMode {
+	case v1.PersistentVolumeBlock:
+		return []*csi.VolumeCapability{
+			{
+				AccessType: getAccessTypeBlock(),
+				AccessMode: &csi.VolumeCapability_AccessMode{Mode: csiAccessMode},
+			},
+		}, nil
+	case v1.PersistentVolumeFilesystem:
+		var mountFlags []string
+		if sc != nil {
+			mountFlags = sc.MountOptions
+		}
+		return []*csi.VolumeCapability{
+			{
+				AccessType: getAccessTypeMount(e.resolveFSType(vrr), mountFlags),
+				AccessMode: &csi.VolumeCapability_AccessMode{Mode: csiAccessMode},
+			},
+		}, nil
+	default:
+		return nil, fmt.Errorf("unsupported volumeMode %q (must be Block or Filesystem)", vrr.Spec.VolumeMode)
+	}
+}
+
+// resolveFSType returns the VRR-requested filesystem type, falling back to the
+// executor default. It is only meaningful for Filesystem volumes.
+func (e *VRRExecutor) resolveFSType(vrr *storagev1alpha1.VolumeRestoreRequest) string {
+	if vrr.Spec.FsType != "" {
+		return vrr.Spec.FsType
+	}
+	return e.defaultFSType
+}
+
+// effectiveAccessModes returns the VRR-requested access modes, defaulting to
+// ReadWriteOnce when none are specified. The returned slice is what is recorded on
+// the PV/PVC verbatim (no lossy reverse-mapping from the single CSI access mode).
+func effectiveAccessModes(vrr *storagev1alpha1.VolumeRestoreRequest) []v1.PersistentVolumeAccessMode {
+	if len(vrr.Spec.AccessModes) > 0 {
+		return vrr.Spec.AccessModes
+	}
+	return []v1.PersistentVolumeAccessMode{v1.ReadWriteOnce}
+}
+
+// validateVRRAccessModes rejects unknown access modes so an invalid spec fails
+// closed in reconcile (an empty list is valid and defaults to ReadWriteOnce). It
+// mirrors the CRD Enum on spec.accessModes for clusters where the CRD predates it.
+func validateVRRAccessModes(modes []v1.PersistentVolumeAccessMode) error {
+	for _, m := range modes {
+		switch m {
+		case v1.ReadWriteOnce, v1.ReadOnlyMany, v1.ReadWriteMany, v1.ReadWriteOncePod:
+		default:
+			return fmt.Errorf("unsupported access mode %q (must be one of ReadWriteOnce, ReadOnlyMany, ReadWriteMany, ReadWriteOncePod)", m)
+		}
+	}
+	return nil
+}
+
+// restoreFromPV restores a volume by cloning an existing PersistentVolume and creates PV + PVC.
+func (e *VRRExecutor) restoreFromPV(ctx context.Context, vrr *storagev1alpha1.VolumeRestoreRequest, sc *storagev1.StorageClass, pvName string) error {
+	sourcePV, err := e.kubeClient.CoreV1().PersistentVolumes().Get(ctx, vrr.Spec.SourceRef.Name, metav1.GetOptions{})
+	if err != nil {
+		if apierrors.IsNotFound(err) {
+			return fmt.Errorf("PersistentVolume %s not found", vrr.Spec.SourceRef.Name)
+		}
+		return fmt.Errorf("failed to get PersistentVolume %s: %w", vrr.Spec.SourceRef.Name, err)
+	}
+
+	if sourcePV.ObjectMeta.DeletionTimestamp != nil {
+		return fmt.Errorf("PersistentVolume %s is currently being deleted", sourcePV.Name)
+	}
+	if sourcePV.Spec.CSI == nil {
+		return fmt.Errorf("PersistentVolume %s does not have CSI source", sourcePV.Name)
+	}
+	if sourcePV.Spec.CSI.Driver != e.driverName {
+		return fmt.Errorf("PersistentVolume %s is handled by a different CSI driver (%s), expected %s", sourcePV.Name, sourcePV.Spec.CSI.Driver, e.driverName)
+	}
+
+	volumeHandle := sourcePV.Spec.CSI.VolumeHandle
+	if volumeHandle == "" {
+		return fmt.Errorf("PersistentVolume %s has empty VolumeHandle", sourcePV.Name)
+	}
+
+	klog.V(2).Infof("restoreFromPV: VRR %s/%s, source PV %s, volumeHandle %s", vrr.Namespace, vrr.Name, sourcePV.Name, volumeHandle)
+
+	volumeCaps, err := e.getVolumeCapabilitiesFromPV(sourcePV, sc)
+	if err != nil {
+		return fmt.Errorf("failed to get volume capabilities from PV: %w", err)
+	}
+
+	capacityBytes := int64(1024 * 1024 * 1024) // 1Gi default
+	if capacity, ok := sourcePV.Spec.Capacity[v1.ResourceStorage]; ok {
+		capacityBytes = capacity.Value()
+	}
+
+	contentSource := &csi.VolumeContentSource{
+		Type: &csi.VolumeContentSource_Volume{
+			Volume: &csi.VolumeContentSource_VolumeSource{
+				VolumeId: volumeHandle,
+			},
+		},
+	}
+
+	pv, err := e.ensurePV(ctx, vrr, sc, pvName, volumeCaps, capacityBytes, contentSource, e.getFSTypeFromPV(sourcePV),
+		fmt.Sprintf("Successfully created PV %s from PersistentVolume %s", pvName, sourcePV.Name), sourcePV.Spec.AccessModes)
+	if err != nil {
+		return err
+	}
+
+	return e.createPVCFromVRR(ctx, vrr, pv)
+}
+
+// ensurePV idempotently provisions the target PV: it returns an existing PV if one
+// is already present, otherwise it calls CSI CreateVolume and creates the PV object.
+func (e *VRRExecutor) ensurePV(
+	ctx context.Context,
+	vrr *storagev1alpha1.VolumeRestoreRequest,
+	sc *storagev1.StorageClass,
+	pvName string,
+	volumeCaps []*csi.VolumeCapability,
+	capacityBytes int64,
+	contentSource *csi.VolumeContentSource,
+	fsType string,
+	pvCreatedMessage string,
+	accessModes []v1.PersistentVolumeAccessMode,
+) (*v1.PersistentVolume, error) {
+	// Idempotency: a previous attempt may have created the PV but not the PVC.
+	if existingPV, err := e.kubeClient.CoreV1().PersistentVolumes().Get(ctx, pvName, metav1.GetOptions{}); err == nil {
+		klog.V(2).Infof("ensurePV: PV %s already exists, reusing it for VRR %s/%s", pvName, vrr.Namespace, vrr.Name)
+		return existingPV, nil
+	} else if !apierrors.IsNotFound(err) {
+		return nil, fmt.Errorf("failed to check if PV %s exists: %w", pvName, err)
+	}
+
+	// Resolve provisioner secret credentials from the StorageClass parameters.
+	// The PVC does not exist yet, so secret templates can only reference the PV name.
+	var provisionerCredentials map[string]string
+	provisionerSecretRef, err := getSecretReference(provisionerSecretParams, sc.Parameters, pvName, nil)
+	if err != nil {
+		// Missing/invalid secret reference is acceptable - some drivers need no secrets.
+		klog.V(5).Infof("ensurePV: no secret reference in StorageClass for VRR %s/%s: %v", vrr.Namespace, vrr.Name, err)
+	} else if provisionerSecretRef != nil {
+		provisionerCredentials, err = getCredentials(ctx, e.kubeClient, provisionerSecretRef)
+		if err != nil {
+			return nil, fmt.Errorf("failed to get provisioner credentials: %w", err)
+		}
+	}
+
+	req := csi.CreateVolumeRequest{
+		Name:                pvName,
+		Parameters:          sc.Parameters,
+		VolumeCapabilities:  volumeCaps,
+		CapacityRange:       &csi.CapacityRange{RequiredBytes: capacityBytes},
+		VolumeContentSource: contentSource,
+		Secrets:             provisionerCredentials,
+	}
+
+	createCtx, cancel := context.WithTimeout(ctx, e.timeout)
+	defer cancel()
+
+	klog.V(2).Infof("ensurePV: calling CSI CreateVolume for VRR %s/%s, volumeName %s", vrr.Namespace, vrr.Name, pvName)
+	rep, err := e.csiClient.CreateVolume(createCtx, &req)
+	if err != nil {
+		return nil, fmt.Errorf("CSI CreateVolume failed: %w", err)
+	}
+	if rep.Volume == nil {
+		return nil, fmt.Errorf("CSI CreateVolume returned nil volume")
+	}
+	klog.V(2).Infof("ensurePV: CSI CreateVolume succeeded for VRR %s/%s, volumeHandle %s", vrr.Namespace, vrr.Name, rep.Volume.VolumeId)
+
+	pv, err := createPVFromCSIResponse(rep.Volume, sc, pvName, e.driverName, e.identity, volumeCaps, fsType, accessModes)
+	if err != nil {
+		return nil, fmt.Errorf("failed to build PV object from CSI response: %w", err)
+	}
+
+	createdPV, err := e.kubeClient.CoreV1().PersistentVolumes().Create(ctx, pv, metav1.CreateOptions{})
+	if err != nil {
+		if apierrors.IsAlreadyExists(err) {
+			// Race: PV created concurrently between Get and Create.
+			existingPV, getErr := e.kubeClient.CoreV1().PersistentVolumes().Get(ctx, pvName, metav1.GetOptions{})
+			if getErr != nil {
+				return nil, fmt.Errorf("PV %s already exists but failed to get it: %w", pvName, getErr)
+			}
+			return existingPV, nil
+		}
+		return nil, fmt.Errorf("failed to create PV %s: %w", pvName, err)
+	}
+
+	klog.V(2).Infof("ensurePV: created PV %s for VRR %s/%s", pvName, vrr.Namespace, vrr.Name)
+	e.eventRecorder.Eventf(vrr, v1.EventTypeNormal, "VRRPVCreated", "%s", pvCreatedMessage)
+	return createdPV, nil
+}
+
+// createPVCFromVRR creates a PersistentVolumeClaim bound to the restored PV.
+//
+// CONTRACT:
+//   - PVC MUST have VolumeName set explicitly (no scheduler binding).
+//   - PVC MUST NOT have dataSource or dataSourceRef (restore without VolumeSnapshot API).
+//   - PVC MAY have an OwnerReference to the ObjectKeeper (from a VRR annotation set by
+//     the storage-foundation controller).
+//   - AlreadyExists is treated as idempotent success.
+func (e *VRRExecutor) createPVCFromVRR(ctx context.Context, vrr *storagev1alpha1.VolumeRestoreRequest, pv *v1.PersistentVolume) error {
+	storageClassName := vrr.Spec.StorageClassName
+	pvc := &v1.PersistentVolumeClaim{
+		ObjectMeta: metav1.ObjectMeta{
+			Name:      vrr.Spec.TargetPVCName,
+			Namespace: vrr.Spec.TargetNamespace,
+		},
+		Spec: v1.PersistentVolumeClaimSpec{
+			StorageClassName: &storageClassName,
+			VolumeName:       pv.Name, // explicit binding, no scheduler
+			AccessModes:      pv.Spec.AccessModes,
+			VolumeMode:       pv.Spec.VolumeMode,
+			Resources: v1.VolumeResourceRequirements{
+				Requests: v1.ResourceList{
+					v1.ResourceStorage: pv.Spec.Capacity[v1.ResourceStorage],
+				},
+			},
+		},
+	}
+
+	// Set the ObjectKeeper OwnerReference if present. The executor trusts the VRR
+	// controller and does not look ObjectKeeper up itself.
+	if refStr, ok := vrr.Annotations[objectKeeperRefAnnotation]; ok && refStr != "" {
+		ownerRef, err := parseObjectKeeperRef(refStr)
+		if err != nil {
+			klog.Warningf("VRR %s/%s: failed to parse ObjectKeeper ref annotation: %v", vrr.Namespace, vrr.Name, err)
+		} else {
+			pvc.OwnerReferences = []metav1.OwnerReference{ownerRef}
+		}
+	}
+
+	if _, err := e.kubeClient.CoreV1().PersistentVolumeClaims(vrr.Spec.TargetNamespace).Create(ctx, pvc, metav1.CreateOptions{}); err != nil {
+		if apierrors.IsAlreadyExists(err) {
+			klog.V(2).Infof("createPVCFromVRR: PVC %s/%s already exists, idempotent success", vrr.Spec.TargetNamespace, vrr.Spec.TargetPVCName)
+			return nil
+		}
+		return fmt.Errorf("failed to create PVC %s/%s: %w", vrr.Spec.TargetNamespace, vrr.Spec.TargetPVCName, err)
+	}
+
+	klog.V(2).Infof("createPVCFromVRR: created PVC %s/%s for VRR %s/%s", vrr.Spec.TargetNamespace, vrr.Spec.TargetPVCName, vrr.Namespace, vrr.Name)
+	e.eventRecorder.Eventf(vrr, v1.EventTypeNormal, "VRRPVCCreated", "Successfully created PVC %s/%s", vrr.Spec.TargetNamespace, vrr.Spec.TargetPVCName)
+	return nil
+}
+
+// parseObjectKeeperRef parses an ObjectKeeper owner reference from an annotation.
+//
+// Expected format: "apiVersion|kind|name|uid"
+// Example: "deckhouse.io/v1alpha1|ObjectKeeper|ret-pvc-abc123|def456"
+//
+// The executor does NOT validate existence - it trusts the VRR controller.
+func parseObjectKeeperRef(refStr string) (metav1.OwnerReference, error) {
+	parts := strings.Split(refStr, "|")
+	if len(parts) != 4 {
+		return metav1.OwnerReference{}, fmt.Errorf("invalid ObjectKeeper ref format: expected 'apiVersion|kind|name|uid', got %d parts", len(parts))
+	}
+
+	apiVersion, kind, name, uid := parts[0], parts[1], parts[2], parts[3]
+	if apiVersion == "" || kind == "" || name == "" || uid == "" {
+		return metav1.OwnerReference{}, fmt.Errorf("invalid ObjectKeeper ref: empty fields not allowed")
+	}
+
+	controller := true
+	return metav1.OwnerReference{
+		APIVersion: apiVersion,
+		Kind:       kind,
+		Name:       name,
+		UID:        types.UID(uid),
+		Controller: &controller,
+	}, nil
+}
+
+// createPVFromCSIResponse builds a PersistentVolume object from a CSI CreateVolume response.
+func createPVFromCSIResponse(
+	volume *csi.Volume,
+	sc *storagev1.StorageClass,
+	pvName string,
+	driverName string,
+	identity string,
+	volumeCaps []*csi.VolumeCapability,
+	fsType string,
+	accessModes []v1.PersistentVolumeAccessMode,
+) (*v1.PersistentVolume, error) {
+	respCap := volume.GetCapacityBytes()
+	if respCap == 0 {
+		// CSI spec: capacity = 0 means unknown, use default.
+		respCap = 1024 * 1024 * 1024 // 1Gi default
+	}
+
+	volumeAttributes := map[string]string{
+		"storage.kubernetes.io/csiProvisionerIdentity": identity,
+	}
+	if volume.VolumeContext != nil {
+		maps.Copy(volumeAttributes, volume.VolumeContext)
+	}
+
+	// Record the requested access modes verbatim. Reverse-mapping the single CSI
+	// access mode back to a PV access mode is lossy (ReadWriteOncePod collapses to
+	// ReadWriteOnce, multi-mode lists collapse to one), so the originally requested
+	// modes are authoritative for the PV/PVC pair.
+	if len(accessModes) == 0 {
+		accessModes = []v1.PersistentVolumeAccessMode{v1.ReadWriteOnce}
+	}
+
+	var volumeMode *v1.PersistentVolumeMode
+	if len(volumeCaps) > 0 {
+		if volumeCaps[0].GetBlock() != nil {
+			blockMode := v1.PersistentVolumeBlock
+			volumeMode = &blockMode
+		} else {
+			fsMode := v1.PersistentVolumeFilesystem
+			volumeMode = &fsMode
+		}
+	}
+
+	pvReadOnly := len(accessModes) == 1 && accessModes[0] == v1.ReadOnlyMany
+
+	csiPVSource := &v1.CSIPersistentVolumeSource{
+		Driver:           driverName,
+		VolumeHandle:     volume.VolumeId,
+		VolumeAttributes: volumeAttributes,
+		ReadOnly:         pvReadOnly,
+	}
+	if volumeMode == nil || *volumeMode == v1.PersistentVolumeFilesystem {
+		csiPVSource.FSType = fsType
+	}
+
+	pv := &v1.PersistentVolume{
+		ObjectMeta: metav1.ObjectMeta{
+			Name: pvName,
+		},
+		Spec: v1.PersistentVolumeSpec{
+			AccessModes:  accessModes,
+			MountOptions: sc.MountOptions,
+			// StorageClassName MUST match the target PVC's StorageClassName, otherwise
+			// the persistentvolume-controller refuses to bind (VolumeMismatch).
+			StorageClassName: sc.Name,
+			Capacity: v1.ResourceList{
+				v1.ResourceStorage: bytesToQuantity(respCap),
+			},
+			PersistentVolumeSource: v1.PersistentVolumeSource{
+				CSI: csiPVSource,
+			},
+			VolumeMode: volumeMode,
+		},
+	}
+
+	// No deletion secrets for VRR-provisioned volumes.
+	metav1.SetMetaDataAnnotation(&pv.ObjectMeta, "volume.kubernetes.io/provisioner-deletion-secret-name", "")
+	metav1.SetMetaDataAnnotation(&pv.ObjectMeta, "volume.kubernetes.io/provisioner-deletion-secret-namespace", "")
+
+	if sc.ReclaimPolicy != nil {
+		pv.Spec.PersistentVolumeReclaimPolicy = *sc.ReclaimPolicy
+	}
+
+	if len(volume.AccessibleTopology) > 0 {
+		pv.Spec.NodeAffinity = GenerateVolumeNodeAffinity(volume.AccessibleTopology)
+	}
+
+	return pv, nil
+}
+
+// getVolumeCapabilitiesFromPV converts PV AccessModes and VolumeMode to CSI VolumeCapabilities.
+func (e *VRRExecutor) getVolumeCapabilitiesFromPV(pv *v1.PersistentVolume, sc *storagev1.StorageClass) ([]*csi.VolumeCapability, error) {
+	supportsSingleNodeMultiWriter := e.controllerCapabilities[csi.ControllerServiceCapability_RPC_SINGLE_NODE_MULTI_WRITER]
+
+	accessModes := pv.Spec.AccessModes
+	if len(accessModes) == 0 {
+		accessModes = []v1.PersistentVolumeAccessMode{v1.ReadWriteOnce}
+	}
+
+	csiAccessMode, err := accessmodes.ToCSIAccessMode(accessModes, supportsSingleNodeMultiWriter)
+	if err != nil {
+		return nil, fmt.Errorf("failed to convert AccessModes to CSI access mode: %w", err)
+	}
+
+	isBlock := pv.Spec.VolumeMode != nil && *pv.Spec.VolumeMode == v1.PersistentVolumeBlock
+	if isBlock {
+		return []*csi.VolumeCapability{
+			{
+				AccessType: getAccessTypeBlock(),
+				AccessMode: &csi.VolumeCapability_AccessMode{Mode: csiAccessMode},
+			},
+		}, nil
+	}
+
+	fsType := e.getFSTypeFromPV(pv)
+	var mountFlags []string
+	if sc != nil {
+		mountFlags = sc.MountOptions
+	}
+
+	return []*csi.VolumeCapability{
+		{
+			AccessType: getAccessTypeMount(fsType, mountFlags),
+			AccessMode: &csi.VolumeCapability_AccessMode{Mode: csiAccessMode},
+		},
+	}, nil
+}
+
+// getFSTypeFromPV extracts FSType from a PV, falling back to the executor default.
+func (e *VRRExecutor) getFSTypeFromPV(pv *v1.PersistentVolume) string {
+	if pv.Spec.CSI != nil && pv.Spec.CSI.FSType != "" {
+		return pv.Spec.CSI.FSType
+	}
+	return e.defaultFSType
+}
+
+// isTerminalVRR reports whether the VRR is in a terminal state (Ready=True or Ready=False).
+// This is a read-only optimization; the executor never writes VRR status.
+func isTerminalVRR(conditions []metav1.Condition) bool {
+	cond := meta.FindStatusCondition(conditions, storagev1alpha1.ConditionTypeReady)
+	return cond != nil && (cond.Status == metav1.ConditionTrue || cond.Status == metav1.ConditionFalse)
+}
