+func TestParseObjectKeeperRef(t *testing.T) {
+	ref, err := parseObjectKeeperRef("deckhouse.io/v1alpha1|ObjectKeeper|ret-pvc|uid-1")
+	if err != nil {
+		t.Fatalf("unexpected error: %v", err)
+	}
+	if ref.Kind != "ObjectKeeper" || ref.Name != "ret-pvc" || string(ref.UID) != "uid-1" {
+		t.Errorf("unexpected owner reference: %+v", ref)
+	}
+	if ref.Controller == nil || !*ref.Controller {
+		t.Error("owner reference should be a controller reference")
+	}
+
+	for _, bad := range []string{"", "a|b|c", "a|b|c|d|e", "|b|c|d", "a||c|d"} {
+		if _, err := parseObjectKeeperRef(bad); err == nil {
