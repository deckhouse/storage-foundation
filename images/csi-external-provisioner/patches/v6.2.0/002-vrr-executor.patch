+func (m *mockStorageClassLister) List(_ labels.Selector) ([]*storagev1.StorageClass, error) {
+	result := make([]*storagev1.StorageClass, 0, len(m.storageClasses))
+	for _, sc := range m.storageClasses {
+		result = append(result, sc)
+	}
+	return result, nil
