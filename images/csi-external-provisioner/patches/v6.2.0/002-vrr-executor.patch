+func TestValidateVRRAccessModes(t *testing.T) {
+	valid := [][]v1.PersistentVolumeAccessMode{
+		nil,
+		{v1.ReadWriteOnce},
+		{v1.ReadOnlyMany},
+		{v1.ReadWriteMany},
+		{v1.ReadWriteOncePod},
+		{v1.ReadWriteOnce, v1.ReadOnlyMany},
+	}
+	for _, modes := range valid {
+		if err := validateVRRAccessModes(modes); err != nil {
+			t.Errorf("validateVRRAccessModes(%v) = %v, want nil", modes, err)
+		}
+	}
+	invalid := [][]v1.PersistentVolumeAccessMode{
+		{"BogusMode"},
+		{v1.ReadWriteOnce, "BogusMode"},
+	}
+	for _, modes := range invalid {
+		if err := validateVRRAccessModes(modes); err == nil {
+			t.Errorf("validateVRRAccessModes(%v) = nil, want error", modes)
+		}
+	}
+}
