+// TestReconcile_InvalidAccessModes verifies an invalid access mode fails closed
+// (warning event, no PVC, no retryable error) symmetrically with VolumeMode.
+func TestReconcile_InvalidAccessModes(t *testing.T) {
+	ctrl := gomock.NewController(t)
+	defer ctrl.Finish()
+
+	mockCSIClient := &mockControllerClient{
+		createVolumeFunc: func(_ context.Context, _ *csi.CreateVolumeRequest) (*csi.CreateVolumeResponse, error) {
+			t.Error("CSI CreateVolume must not be called for invalid accessModes")
+			return nil, nil
+		},
+	}
+	mockSCLister := NewMockStorageClassLister(ctrl)
+	mockSCLister.storageClasses[vrrTestStorageClass] = ourStorageClass()
+
+	vrr := createTestVRR("test-vrr", "test-ns", "VolumeSnapshotContent", "test-vsc")
+	vrr.Spec.AccessModes = []v1.PersistentVolumeAccessMode{"BogusMode"}
+
+	kubeClient := fakeclientset.NewSimpleClientset()
+	eventRecorder := record.NewFakeRecorder(10)
+	e := newTestExecutor(mockCSIClient, mockSCLister, kubeClient, nil, eventRecorder)
+
+	if err := e.reconcile(context.Background(), vrr); err != nil {
+		t.Fatalf("reconcile should not return an error for invalid accessModes: %v", err)
+	}
+	if !waitForEvent(eventRecorder, "VRRInvalidSpec") {
+		t.Error("Expected event with reason VRRInvalidSpec for invalid accessModes")
+	}
+	assertNoPVC(t, kubeClient)
+}
