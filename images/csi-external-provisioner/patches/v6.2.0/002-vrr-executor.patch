+func waitForEvent(recorder *record.FakeRecorder, reason string) bool {
+	for {
+		select {
+		case event := <-recorder.Events:
+			if strings.Contains(event, reason) {
+				return true
+			}
+		default:
+			return false
+		}
+	}
+}
