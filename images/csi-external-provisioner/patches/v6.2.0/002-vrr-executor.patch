+// TestCreatePVFromCSIResponse_RequestedAccessModes verifies the PV records the
+// requested access modes verbatim (no lossy reverse-map from the CSI access mode):
+// ReadWriteOncePod must not collapse to ReadWriteOnce, and a multi-mode list is kept.
+func TestCreatePVFromCSIResponse_RequestedAccessModes(t *testing.T) {
+	volume := &csi.Volume{VolumeId: "test-volume-id", CapacityBytes: 1024 * 1024 * 1024}
+	sc := ourStorageClass()
+	// CSI access mode is SINGLE_NODE_WRITER (what RWOP maps to), but the requested
+	// PV access mode must remain ReadWriteOncePod.
+	volumeCaps := []*csi.VolumeCapability{
+		{
+			AccessType: getAccessTypeMount("ext4", nil),
+			AccessMode: &csi.VolumeCapability_AccessMode{Mode: csi.VolumeCapability_AccessMode_SINGLE_NODE_WRITER},
+		},
+	}
+
+	pv, err := createPVFromCSIResponse(volume, sc, "test-pv", vrrTestDriverName, vrrTestIdentity, volumeCaps, "ext4",
+		[]v1.PersistentVolumeAccessMode{v1.ReadWriteOncePod})
+	if err != nil {
+		t.Fatalf("createPVFromCSIResponse failed: %v", err)
+	}
+	if len(pv.Spec.AccessModes) != 1 || pv.Spec.AccessModes[0] != v1.ReadWriteOncePod {
+		t.Errorf("Expected AccessModes [ReadWriteOncePod] (no collapse), got %v", pv.Spec.AccessModes)
+	}
+	if pv.Spec.PersistentVolumeSource.CSI.ReadOnly {
+		t.Error("PV should not be ReadOnly for ReadWriteOncePod")
+	}
+
+	// Empty requested modes default to ReadWriteOnce.
+	pvDefault, err := createPVFromCSIResponse(volume, sc, "test-pv2", vrrTestDriverName, vrrTestIdentity, volumeCaps, "ext4", nil)
+	if err != nil {
+		t.Fatalf("createPVFromCSIResponse failed: %v", err)
+	}
+	if len(pvDefault.Spec.AccessModes) != 1 || pvDefault.Spec.AccessModes[0] != v1.ReadWriteOnce {
+		t.Errorf("Expected default AccessModes [ReadWriteOnce], got %v", pvDefault.Spec.AccessModes)
+	}
