+// TestReconcile_DriverFilter verifies that the executor ignores VRRs whose
+// StorageClass does not target this CSI driver (or does not exist).
+func TestReconcile_DriverFilter(t *testing.T) {
+	tests := []struct {
+		name          string
+		storageClass  *storagev1.StorageClass
+		scListerError error
+	}{
+		{
+			name: "different driver - should ignore",
+			storageClass: &storagev1.StorageClass{
+				ObjectMeta:  metav1.ObjectMeta{Name: vrrTestStorageClass},
+				Provisioner: "other-driver",
+			},
+		},
+		{
+			name:          "storage class not found - should ignore",
+			scListerError: apierrors.NewNotFound(storagev1.Resource("storageclass"), vrrTestStorageClass),
+		},
+	}
+
+	for _, tt := range tests {
+		t.Run(tt.name, func(t *testing.T) {
+			ctrl := gomock.NewController(t)
+			defer ctrl.Finish()
+
+			mockCSIClient := &mockControllerClient{
+				createVolumeFunc: func(_ context.Context, _ *csi.CreateVolumeRequest) (*csi.CreateVolumeResponse, error) {
+					t.Error("CSI CreateVolume must not be called for a foreign/unknown StorageClass")
+					return nil, nil
+				},
+			}
+			mockSCLister := NewMockStorageClassLister(ctrl)
+			if tt.scListerError != nil {
+				mockSCLister.errors[vrrTestStorageClass] = tt.scListerError
+			} else if tt.storageClass != nil {
+				mockSCLister.storageClasses[vrrTestStorageClass] = tt.storageClass
+			}
+
+			kubeClient := fakeclientset.NewSimpleClientset()
+			e := newTestExecutor(mockCSIClient, mockSCLister, kubeClient, nil, nil)
+
+			vrr := createTestVRR("test-vrr", "test-ns", "VolumeSnapshotContent", "test-vsc")
+			if err := e.reconcile(context.Background(), vrr); err != nil {
+				t.Fatalf("reconcile returned unexpected error: %v", err)
+			}
+
+			assertNoPVC(t, kubeClient)
+		})
+	}
+}
