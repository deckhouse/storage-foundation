+	// Deckhouse fork: VolumeSnapshots whose source is a DataImport are owned by the state-snapshotter
+	// common controller (import flow). The snapshot-controller MUST NOT reconcile them: it would not
+	// understand the dataImportName source, would fail source validation, and would fight the common
+	// controller over status. Skip entirely (no finalizers, no status writes).
+	if snapshot.Spec.Source.DataImportName != nil {
+		klog.V(5).Infof("syncSnapshot[%s]: skipping VolumeSnapshot with DataImport source (owned by state-snapshotter)", utils.SnapshotKey(snapshot))
+		return nil
+	}
+
