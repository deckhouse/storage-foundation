+	// Deckhouse fork: VolumeSnapshots that carry the import marker (spec.source.import) are owned by
+	// the state-snapshotter common controller (import flow). The snapshot-controller MUST NOT reconcile
+	// them: it would not understand the import source, would fail source validation, and would fight the
+	// common controller over status. Skip entirely (no finalizers, no status writes).
+	if snapshot.Spec.Source.Import != nil {
+		klog.V(5).Infof("syncSnapshot[%s]: skipping VolumeSnapshot with import-marker source (owned by state-snapshotter)", utils.SnapshotKey(snapshot))
+		return nil
+	}
